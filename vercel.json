{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "crons": [
    {
      "path": "/api/cron/daily-jobs",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/keep-alive",
      "schedule": "0 12 * * *"
    }
  ]
}
